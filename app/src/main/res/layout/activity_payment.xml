<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/spacing_16"
    android:background="@color/light_gray">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Payment Details"
        android:textSize="@dimen/text_size_24"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="@dimen/spacing_24" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_24"
        android:elevation="@dimen/spacing_8">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_16">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Order Summary"
                android:textSize="@dimen/text_size_18"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_16" />

            <TextView
                android:id="@+id/orderSummaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_size_16"
                android:layout_marginBottom="@dimen/spacing_8" />

            <TextView
                android:id="@+id/amountText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_size_20"
                android:textStyle="bold"
                android:textColor="@color/primary" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="@dimen/spacing_16">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Card Information"
                android:textSize="@dimen/text_size_18"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_16" />

            <EditText
                android:id="@+id/cardNumberInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Card Number"
                android:inputType="number"
                android:padding="@dimen/spacing_12"
                android:layout_marginBottom="@dimen/spacing_12"
                android:background="@color/white"
                android:textSize="@dimen/text_size_16" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_12">

                <EditText
                    android:id="@+id/expiryInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="MM/YY"
                    android:inputType="text"
                    android:padding="@dimen/spacing_12"
                    android:background="@color/white"
                    android:textSize="@dimen/text_size_16"
                    android:layout_marginEnd="@dimen/spacing_8" />

                <EditText
                    android:id="@+id/cvvInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="CVV"
                    android:inputType="number"
                    android:padding="@dimen/spacing_12"
                    android:background="@color/white"
                    android:textSize="@dimen/text_size_16" />
            </LinearLayout>

            <EditText
                android:id="@+id/cardHolderInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Cardholder Name"
                android:inputType="text"
                android:padding="@dimen/spacing_12"
                android:layout_marginBottom="@dimen/spacing_12"
                android:background="@color/white"
                android:textSize="@dimen/text_size_16" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔒 Your payment is secure"
                android:textSize="@dimen/text_size_14"
                android:textColor="@color/green"
                android:layout_marginTop="@dimen/spacing_16" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/spacing_16">

        <Button
            android:id="@+id/cancelButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancel"
            android:padding="@dimen/spacing_16"
            android:background="@color/light_gray"
            android:textColor="@color/primary"
            android:layout_marginEnd="@dimen/spacing_8" />

        <Button
            android:id="@+id/payButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pay Now"
            android:textSize="@dimen/text_size_18"
            android:padding="@dimen/spacing_16"
            android:background="@color/primary"
            android:textColor="@color/white" />
    </LinearLayout>

</LinearLayout>
