<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gray_50">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/white"
        android:padding="16dp"
        android:elevation="2dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Checkout"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/gray_900" />
        <Button
            android:id="@+id/closeButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="✕"
            android:textSize="20sp"
            android:background="@drawable/button_outline_bg"
            android:textColor="@color/gray_600" />
    </LinearLayout>

    <!-- Plan Details Card -->
    <androidx.cardview.widget.CardView xmlns:cardview="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        cardview:cardCornerRadius="12dp"
        cardview:cardElevation="4dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@color/white">

            <TextView
                android:id="@+id/planNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Plan Name"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/gray_900"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/gray_50"
                    android:padding="12dp"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Data"
                        android:textSize="12sp"
                        android:textColor="@color/gray_600"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/dataText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5GB"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/gray_200"
                    android:layout_margin="8dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/gray_50"
                    android:padding="12dp"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Validity"
                        android:textSize="12sp"
                        android:textColor="@color/gray_600"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/validityText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30 days"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/gray_200"
                    android:layout_margin="8dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/gray_50"
                    android:padding="12dp"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Price"
                        android:textSize="12sp"
                        android:textColor="@color/gray_600"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/priceText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$29.99"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/success" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Country"
                    android:textSize="12sp"
                    android:textColor="@color/gray_600" />
                <TextView
                    android:id="@+id/countryText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="USA"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/gray_900" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Payment Methods -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Payment Method"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/gray_900"
            android:layout_marginBottom="12dp" />

        <RadioGroup
            android:id="@+id/paymentMethodGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/creditCardRadio"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="💳 Credit/Debit Card"
                android:textColor="@color/gray_900"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/radio_button_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical"
                android:checked="true" />

            <RadioButton
                android:id="@+id/googlePayRadio"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="🔵 Google Pay"
                android:textColor="@color/gray_900"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/radio_button_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical" />

            <RadioButton
                android:id="@+id/bankTransferRadio"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="🏦 Bank Transfer"
                android:textColor="@color/gray_900"
                android:textSize="14sp"
                android:background="@drawable/radio_button_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical" />
        </RadioGroup>
    </LinearLayout>

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Action Buttons at Bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="bottom"
        android:background="@color/white"
        android:elevation="8dp">

        <Button
            android:id="@+id/cancelButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:textColor="@color/gray_900"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/button_secondary_bg"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:gravity="center_vertical|center_horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="Cancel payment"
            android:elevation="2dp" />

        <Button
            android:id="@+id/payNowButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Proceed"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/button_primary_bg"
            android:gravity="center_vertical|center_horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginStart="8dp"
            android:elevation="2dp" />
    </LinearLayout>

</LinearLayout>