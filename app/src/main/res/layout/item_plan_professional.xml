<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:cardview="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    cardview:cardCornerRadius="12dp"
    cardview:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/white">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/planCountry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="USA"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/planName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5GB High Speed"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/gray_900" />
            </LinearLayout>

            <TextView
                android:id="@+id/planPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$29.99"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/success" />
        </LinearLayout>

        <!-- Details -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp"
            android:background="@color/gray_50"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊"
                    android:textSize="20sp"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:id="@+id/planData"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 GB"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/gray_900" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Data"
                    android:textSize="10sp"
                    android:textColor="@color/gray_500" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/gray_200" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅"
                    android:textSize="20sp"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:id="@+id/planValidity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30 Days"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/gray_900" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Validity"
                    android:textSize="10sp"
                    android:textColor="@color/gray_500" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/gray_200" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📡"
                    android:textSize="20sp"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:id="@+id/planSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4G/5G"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/gray_900" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Speed"
                    android:textSize="10sp"
                    android:textColor="@color/gray_500" />
            </LinearLayout>
        </LinearLayout>

        <!-- Description -->
        <TextView
            android:id="@+id/planDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="High-speed 4G/5G data for streaming and browsing"
            android:textSize="12sp"
            android:textColor="@color/gray_600"
            android:layout_marginBottom="12dp" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            
            <Button
                android:id="@+id/wishlistButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="❤️ Wishlist"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:background="@drawable/button_outline_bg"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/buyPlanButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Buy Plan"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/button_primary_bg" />
        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>