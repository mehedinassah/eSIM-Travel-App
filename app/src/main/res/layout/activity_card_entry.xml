<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Header with Back Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/white"
        android:padding="@dimen/spacing_16">

        <Button
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textSize="20sp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:textColor="@color/gray_600" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Card Payment"
            android:textSize="@dimen/text_size_20"
            android:textStyle="bold"
            android:textColor="@color/gray_900"
            android:layout_marginStart="@dimen/spacing_16" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/gray_200" />

    <!-- Main Form Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_24">

            <!-- Form Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Card Details"
                android:textSize="@dimen/text_size_18"
                android:textStyle="bold"
                android:textColor="@color/gray_900"
                android:layout_marginBottom="@dimen/spacing_16" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enter your card number, expiration date, and CVC"
                android:textSize="@dimen/text_size_14"
                android:textColor="@color/gray_600"
                android:layout_marginBottom="@dimen/spacing_24" />

            <!-- Card Input Widget -->
            <com.stripe.android.view.CardInputWidget
                android:id="@+id/cardInputWidget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_24"
                android:background="@color/white"
                android:padding="@dimen/spacing_12" />

            <!-- Card Type Status (Minimal) -->
            <TextView
                android:id="@+id/cardTypeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Card type detected automatically"
                android:textSize="@dimen/text_size_12"
                android:textColor="@color/gray_500"
                android:layout_marginBottom="@dimen/spacing_32" />

            <!-- Continue Button -->
            <Button
                android:id="@+id/continueButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Continue to Payment"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_16"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:background="@color/primary"
                android:padding="@dimen/spacing_16"
                android:layout_marginBottom="@dimen/spacing_12" />

            <!-- Cancel Button -->
            <Button
                android:id="@+id/cancelButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Cancel"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_size_16"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:background="@drawable/button_outline_bg"
                android:padding="@dimen/spacing_16" />
        </LinearLayout>
    </ScrollView>

</LinearLayout>
